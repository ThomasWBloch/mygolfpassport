# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code lokal state (må aldrig committes)
.claude/

# Interne working-docs (ikke til partnere)
MGP_Partner_Guide_Courses_Database.docx
danish-club-validation.xlsx

# Store data-artefakter (genereres af scripts — holdes ude af repo'et)
scripts/courses-backup-*.json
scripts/*-backup-*.json

# Working-state fra imports (midlertidige — ikke interessante for andre)
scripts/usa-progress.json
scripts/import-progress.json
scripts/canada-australia-progress.json
scripts/*-progress.json

# Logs og debug
scripts/*.log
scripts/finnish-debug.html

# Regenerable script-outputs (ikke i repo — kan regenereres)
scripts/*-report.json
scripts/sweden-test.json
scripts/import-log.json

# Supabase temp-filer
supabase/.temp/

# Pass 1 scraping pipeline — regenerable data (large, shifts over time)
scripts/*/[a-z]*-clubs-osm.json
scripts/*/[a-z]*-{gi,sg,wg,eg}-clubs.json
